# Copier vers .env (non versionné) et renseigner des valeurs réelles pour le dev local :
#   cp .env.example .env
# Aucune valeur réelle ne doit être committée (.env est gitignoré). Politique de gestion des
# secrets (dev / CI / prod / rotation) : voir la section « Gestion des secrets » du README.
# Génère des secrets forts, p. ex. :  openssl rand -base64 24

# ===== PostgreSQL =====
POSTGRES_DB=loyertracker
POSTGRES_USER=loyertracker
POSTGRES_PASSWORD=CHANGE_ME

# ===== Backend (API) =====
DB_URL=jdbc:postgresql://postgres:5432/loyertracker
# Rôle applicatif runtime à privilèges minimaux (NOSUPERUSER/NOBYPASSRLS) — créé par la migration
# V5 ; sous ce rôle la RLS FORCE s'applique réellement (ADR-01). Son mot de passe est aussi injecté
# dans V5 via le placeholder Flyway api_password (application.yml) : garder les deux cohérents.
DB_APP_USER=loyertracker_api
DB_APP_PASSWORD=CHANGE_ME
# Les migrations Flyway tournent via le rôle ADMIN = POSTGRES_USER/POSTGRES_PASSWORD (ci-dessus).
# Rôle technique du batch (BYPASSRLS) — cf. Étape 06 / ADR-01
DB_BATCH_USER=loyertracker_batch
DB_BATCH_PASSWORD=CHANGE_ME
KEYCLOAK_ISSUER_URI=https://localhost/auth/realms/loyertracker
# JWKS atteignable depuis le conteneur api (réseau interne), alors que l'issuer reste public
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/auth/realms/loyertracker/protocol/openid-connect/certs
# Admin API Keycloak (US-12, ADR-10, R6) — création/rattachement gestionnaire.
# base-url interne (réseau Docker) ; inclut le chemin relatif /auth (KC --http-relative-path=/auth).
KEYCLOAK_ADMIN_BASE_URL=http://keycloak:8080/auth
KEYCLOAK_REALM=loyertracker
# Client confidentiel à service account dédié à l'Admin API (distinct du resource-server bearer-only).
KEYCLOAK_API_CLIENT_ID=loyertracker-admin

# ===== Keycloak =====
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
# Secret du client confidentiel loyertracker-admin (service account, Admin API US-12/R6).
# Injecté post-import dans Keycloak par le service keycloak-init (jamais versionné dans le
# realm) ET fourni au conteneur api : les deux valeurs DOIVENT être identiques.
KEYCLOAK_API_CLIENT_SECRET=CHANGE_ME
# Mot de passe du compte de test DEV bailleur-test@test.local — injecté après import
# par le service keycloak-init (jamais versionné). Dev uniquement.
KEYCLOAK_TEST_BAILLEUR_PASSWORD=CHANGE_ME

# ===== TLS (dev) =====
# Pas de variable ici : Nginx monte le dossier ./infra/nginx/certs/ (gitignoré). Générer un
# certificat localhost auto-signé approuvé via mkcert, puis le placer dans ce dossier :
#   mkcert -install
#   mkcert -cert-file infra/nginx/certs/localhost.pem -key-file infra/nginx/certs/localhost-key.pem localhost
# Les *.pem / *.key ne sont jamais versionnés (cf. .gitignore).

# ===== Observabilité / Alerting (overlay docker-compose.monitoring.yml, profil « monitoring », opt-in) =====
# Activation (dev) :     docker compose -f docker-compose.yml         -f docker-compose.monitoring.yml --profile monitoring up -d
# Activation (staging) : docker compose -f docker-compose.staging.yml -f docker-compose.monitoring.yml --profile monitoring up -d
# URL webhook de notification d'Alertmanager (Slack/Teams/Mattermost/pont e-mail…). Peut
# contenir un jeton : injectée au démarrage, JAMAIS versionnée. Requise si le profil est actif.
ALERTMANAGER_WEBHOOK_URL=https://CHANGE_ME/hooks/xxxxx
# Endpoint Pushgateway pour le heartbeat du cron de sauvegarde (hôte → loopback). Défaut interne.
PUSHGATEWAY_URL=http://127.0.0.1:9091
