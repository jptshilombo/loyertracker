# Copier vers .env (non versionné) et renseigner des valeurs réelles pour le dev local :
#   cp .env.example .env
# Aucune valeur réelle ne doit être committée (.env est gitignoré). Politique de gestion des
# secrets (dev / CI / prod / rotation) : voir la section « Gestion des secrets » du README.
# Génère des secrets forts, p. ex. :  openssl rand -base64 24

# ===== PostgreSQL =====
POSTGRES_DB=loyertracker
POSTGRES_USER=loyertracker
POSTGRES_PASSWORD=CHANGE_ME

# ===== Backend (API) =====
DB_URL=jdbc:postgresql://postgres:5432/loyertracker
DB_USER=loyertracker
DB_PASSWORD=CHANGE_ME
# Rôle technique du batch (BYPASSRLS) — cf. Étape 06 / ADR-01
DB_BATCH_USER=loyertracker_batch
DB_BATCH_PASSWORD=CHANGE_ME
KEYCLOAK_ISSUER_URI=https://localhost/auth/realms/loyertracker
# JWKS atteignable depuis le conteneur api (réseau interne), alors que l'issuer reste public
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/auth/realms/loyertracker/protocol/openid-connect/certs

# ===== Keycloak =====
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
# Réservé : secret d'un futur service-account confidentiel (appels Admin API pour
# l'inscription bailleur). Le resource-server loyertracker-api (bearer-only) valide les
# JWT via JWKS et n'a PAS besoin de secret. Câblé à l'étape métier "inscription".
KEYCLOAK_API_CLIENT_SECRET=CHANGE_ME
# Mot de passe du compte de test DEV bailleur-test@test.local — injecté après import
# par le service keycloak-init (jamais versionné). Dev uniquement.
KEYCLOAK_TEST_BAILLEUR_PASSWORD=CHANGE_ME

# ===== TLS (dev) =====
# Pas de variable ici : Nginx monte le dossier ./infra/nginx/certs/ (gitignoré). Générer un
# certificat localhost auto-signé approuvé via mkcert, puis le placer dans ce dossier :
#   mkcert -install
#   mkcert -cert-file infra/nginx/certs/localhost.pem -key-file infra/nginx/certs/localhost-key.pem localhost
# Les *.pem / *.key ne sont jamais versionnés (cf. .gitignore).
